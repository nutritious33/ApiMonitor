# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── PostgreSQL (production) ──────────────────────────────────────────────────
DATASOURCE_USERNAME=apimonitor
DATASOURCE_PASSWORD=change-me-in-production

# ── API Security key (sent as X-API-Key header for all POST requests) ─────────
API_SECURITY_KEY=change-me-in-production

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Obtain your token at https://one.dash.cloudflare.com → Zero Trust → Tunnels
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# ── Optional overrides ───────────────────────────────────────────────────────
# MONITOR_CHECK_INTERVAL_MS=60000   # Health check frequency in ms (default: 60 000)
# SPRING_PROFILES_ACTIVE=prod       # Set by docker-compose automatically
# CORS_ALLOWED_ORIGINS=https://your-tunnel.trycloudflare.com  # Comma-separated; default: localhost only

# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── PostgreSQL (production) ──────────────────────────────────────────────────
DATASOURCE_USERNAME=apimonitor
DATASOURCE_PASSWORD=change-me-in-production

# ── API Security key (sent as X-API-Key header for all POST requests) ─────────
SECRET_SECURITY_KEY=change-me-in-production

# ── React frontend build key (baked into the JS bundle at build time) ──────────
# Reference SECRET_SECURITY_KEY

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Obtain your token at https://one.dash.cloudflare.com → Zero Trust → Tunnels
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
CORS_ALLOWED_ORIGINS=https://subdomain.yourdomain.com
# ── Email notifications (optional — leave blank or omit to disable) ──────────
# When MAIL_HOST is set, the app emails MAIL_TO on every new public submission.
# Leave all of these blank (or omit them) to run without email notifications.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user@example.com
MAIL_PASSWORD=change-me-in-production
MAIL_TO=admin@example.com

# ── Optional overrides ───────────────────────────────────────────────────────
# MONITOR_CHECK_INTERVAL_MS=60000   # Health check frequency in ms (default: 60 000)
# SPRING_PROFILES_ACTIVE=prod       # Set by docker-compose automatically
